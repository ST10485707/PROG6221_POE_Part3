<Window x:Class="PROG6221_POE_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Assistant - Part 3" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D2D">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🛡️ CYBERSECURITY ASSISTANT - PART 3 🛡️"
                           FontSize="20" FontWeight="Bold" Foreground="Cyan"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Chat Display -->
        <ListBox x:Name="ChatDisplay" Grid.Row="1" Margin="10" 
                 Background="#252526" Foreground="#DCDCDC" FontSize="13"
                 FontFamily="Consolas">
            <ListBox.Resources>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </ListBox.Resources>
        </ListBox>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#2D2D2D" Padding="10" Margin="10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="You: " FontWeight="Bold" Foreground="Magenta" 
                           FontSize="14" VerticalAlignment="Center"/>

                <TextBox x:Name="UserInput" Grid.Column="1" Margin="10,0" 
                         Background="#3E3E42" Foreground="White" FontSize="14"
                         BorderBrush="#555" BorderThickness="1" Padding="5"
                         KeyDown="UserInput_KeyDown"/>

                <Button x:Name="SendButton" Grid.Column="2" Content="Send" 
                        Width="70" Height="30" Click="SendButton_Click"
                        Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Quick Action Buttons -->
        <Border Grid.Row="3" Background="#2D2D2D" Padding="5" Margin="10,0,10,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                <Button x:Name="ViewTasksButton" Content="📋 View Tasks" 
                        Width="100" Height="30" Margin="5" Click="ViewTasksButton_Click"
                        Background="#555" Foreground="White"/>
                <Button x:Name="StartQuizButton" Content="🎯 Start Quiz" 
                        Width="100" Height="30" Margin="5" Click="StartQuizButton_Click"
                        Background="#555" Foreground="White"/>
                <Button x:Name="ShowLogButton" Content="📜 Activity Log" 
                        Width="100" Height="30" Margin="5" Click="ShowLogButton_Click"
                        Background="#555" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>